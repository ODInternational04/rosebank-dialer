# =============================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in the actual values
# =============================================

# ============ CRITICAL SECURITY SETTINGS ============
# Generate a strong JWT secret (minimum 32 characters)
# Use: openssl rand -base64 64
JWT_SECRET=your-ultra-secure-jwt-secret-minimum-32-characters-long

# ============ SUPABASE CONFIGURATION ============
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============ NEXT.JS CONFIGURATION ============
# Set to production for live deployment
NODE_ENV=production

# Your production domain (required for HTTPS and security headers)
NEXTAUTH_URL=https://your-domain.com

# ============ DATABASE CONFIGURATION ============
# Optional: Direct database URL for advanced operations
DATABASE_URL=postgresql://user:password@host:port/database

# ============ EMAIL CONFIGURATION ============
# For email notifications (if implemented)
EMAIL_FROM=noreply@your-domain.com
EMAIL_SERVICE_API_KEY=your-email-service-api-key

# ============ EXTERNAL INTEGRATIONS ============
# 3CX Integration (if used)
THREECX_SERVER_URL=https://your-3cx-server.com
THREECX_API_KEY=your-3cx-api-key

# ============ MONITORING & LOGGING ============
# For production monitoring
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# ============ SECURITY HEADERS ============
# Additional security configuration
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CONTENT_SECURITY_POLICY_REPORT_URI=https://your-domain.com/api/csp-report

# ============ RATE LIMITING ============
# Redis configuration for distributed rate limiting (optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# ============ FILE UPLOADS ============
# If you implement file upload features
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# ============ ANALYTICS ============
# Optional analytics integration
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
HOTJAR_ID=your-hotjar-id

# ============ BACKUP CONFIGURATION ============
# Database backup settings
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_URL=s3://your-backup-bucket

# ============ DEVELOPMENT/DEBUGGING ============
# Set to false in production
DEBUG=false
ENABLE_QUERY_LOGGING=false